{
  "manifest_version": 3,
  "name": "Яндекс.Музыка — глобальные хоткеи",
  "version": "1.0.0",
  "description": "Управление Яндекс.Музыкой с любой вкладки: пауза, треки, громкость",
  "permissions": ["commands", "tabs", "scripting", "storage"],
  "host_permissions": [
    "https://music.yandex.ru/*",
    "https://music.yandex.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.yandex.ru/*", "https://music.yandex.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ЯМ Хоткеи"
  },
  "commands": {
    "play-pause": {
      "suggested_key": {
        "default": "Alt+P"
      },
      "description": "Воспроизведение / Пауза"
    },
    "next-track": {
      "suggested_key": {
        "default": "Alt+Right"
      },
      "description": "Следующий трек"
    },
    "prev-track": {
      "suggested_key": {
        "default": "Alt+Left"
      },
      "description": "Предыдущий трек"
    },
    "volume-up": {
      "suggested_key": {
        "default": "Alt+Up"
      },
      "description": "Громче (+10%)"
    }
  }
}
