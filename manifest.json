{
  "manifest_version": 3,
  "name": "Яндекс.Музыка — глобальные хоткеи",
  "version": "1.2.0",
  "description": "Управление Яндекс.Музыкой с любой вкладки: пауза, треки, громкость",
  "permissions": [
    "commands",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://music.yandex.ru/*",
    "https://music.yandex.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://music.yandex.ru/*",
        "https://music.yandex.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ЯМ Хоткеи"
  },
  "commands": {
    "play-pause": {
      "suggested_key": {
        "default": "Alt+P"
      },
      "description": "Воспроизведение / Пауза"
    },
    "next-track": {
      "suggested_key": {
        "default": "Alt+Right"
      },
      "description": "Следующий трек"
    },
    "volume-up": {
      "suggested_key": {
        "default": "Alt+Up"
      },
      "description": "Громче (+10%)"
    },
    "volume-down": {
      "suggested_key": {
        "default": "Alt+Down"
      },
      "description": "Тише (-10%)"
    }
  }
}